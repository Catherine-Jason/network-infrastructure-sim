{
  "id": "scenario1_basicLAN",
  "name": "Basic LAN",
  "devices": [
    {
      "type": "pc",
      "name": "PC1",
      "x": 200,
      "y": 300,
      "interface": {
        "ip": "192.168.1.10",
        "mask": "255.255.255.0",
        "gateway": "192.168.1.1"
      }
    },
    {
      "type": "router",
      "name": "R1",
      "x": 400,
      "y": 300,
      "interfaces": {
        "g0/0": { "ip": "192.168.1.1", "mask": "255.255.255.0" }
      }
    }
  ],
  "links": [
    { "id": "L1", "a": "pc_1", "b": "router_1" }
  ],
  "validation": [
    {
      "type": "ping",
      "source": "pc_1",
      "target": "router_1"
    }
  ],
  "hints": [
    "Check the IP address on PC1.",
    "Verify the router interface IP.",
    "Ensure both devices are in the same subnet."
  ]
}

